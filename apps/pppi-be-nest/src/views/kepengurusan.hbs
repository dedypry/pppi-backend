<html lang='id'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>Data Kepengurusan PPPI</title>
    <style>
      body {
        font-family: Arial, Helvetica, sans-serif;
        color: #111827;
        margin: 16px;
        font-size: 10px;
      }
      .header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        margin-bottom: 12px;
      }
      .title {
        font-size: 18px;
        font-weight: 700;
      }
      .muted {
        color: #6b7280;
      }
      table {
        width: 100%;
        border-collapse: collapse;
      }
      th,
      td {
        border: 1px solid #e5e7eb;
        padding: 6px 8px;
        text-align: left;
        vertical-align: top;
      }
      th {
        background: #f3f4f6;
        font-weight: 700;
      }
      tr:nth-child(even) td {
        background: #fafafa;
      }
      @media print {
        body {
          margin: 0;
          padding: 8mm;
        }
      }
    </style>
  </head>
  <body>
    <div class='header'>
      <div>
        <div class='title'>Data Kepengurusan PPPI</div>
        <div class='muted'>Total: {{total}} orang</div>
      </div>
      <div class='muted'>Dicetak: {{generated_at}}</div>
    </div>

    <table>
      <thead>
        <tr>
          <th>No</th>
          <th>Wilayah</th>
          <th>Pengurus</th>
          <th>Jabatan</th>
          <th>Nama</th>
          <th>NIA</th>
          <th>Email</th>
          <th>Phone</th>
          <th>Status Verifikasi</th>
          <th>Status Anggota</th>
        </tr>
      </thead>
      <tbody>
        {{#each rows}}
          <tr>
            <td>{{no}}</td>
            <td>{{wilayah}}</td>
            <td>{{pengurus}}</td>
            <td>{{jabatan}}</td>
            <td>{{nama}}</td>
            <td>{{nia}}</td>
            <td>{{email}}</td>
            <td>{{phone}}</td>
            <td>{{verification_status}}</td>
            <td>{{status}}</td>
          </tr>
        {{/each}}
      </tbody>
    </table>
  </body>
</html>
